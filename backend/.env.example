# Configuración API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Base de datos (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/centro

# JWT
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS (Next.js dev)
CORS_ORIGINS=http://localhost:3000

# Storage físico (Etapa 2 - volumen RAID)
STORAGE_BACKEND=local
STORAGE_ROOT=./var/storage

# Embeddings (Etapa 3)
EMBEDDING_DIM=1536
# `fake` para dev sin conectividad; `openai` para text-embedding-3-*
EMBEDDING_BACKEND=fake
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# OCR (Etapa 3) — requiere tesseract instalado en el sistema:
#   sudo apt install tesseract-ocr tesseract-ocr-spa tesseract-ocr-eng
OCR_LANGS=spa+eng

# Asistente IA (Etapa 4)
# `fake` para dev sin tokens, `openai` o `groq` para LLM real.
LLM_BACKEND=fake
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=600
LLM_TOP_K=5
GROQ_API_KEY=
