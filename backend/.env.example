# Configuración API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Base de datos (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/centro

# JWT
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS (Next.js dev)
CORS_ORIGINS=http://localhost:3000

# Storage físico (Etapa 2 - volumen RAID)
STORAGE_BACKEND=local
STORAGE_ROOT=./var/storage

# Embeddings (Etapa 3)
EMBEDDING_DIM=1536
