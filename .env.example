# ================================================================
# Variables para docker compose (deploy del monorepo)
# Copiá este archivo como `.env` en la raíz del proyecto.
# ================================================================

# Base de datos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-pass
POSTGRES_DB=centro

# Autenticación
JWT_SECRET=cambia-este-secreto-largo-en-produccion

# CORS: dominios desde los que el frontend pega al backend.
# Cloudflare Tunnel termina TLS y reenvía al contenedor por la
# red interna, así que es el dominio público del frontend.
CORS_ORIGINS=https://prueba.lyntrix.com.ar

# Embeddings (Etapa 3)
EMBEDDING_BACKEND=fake
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# OCR (sólo afecta JPEG/PNG)
OCR_LANGS=spa+eng

# LLM (Etapa 4)
LLM_BACKEND=fake
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=600
LLM_TOP_K=5
GROQ_API_KEY=
