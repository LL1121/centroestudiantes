# ================================================================
# Variables para docker compose (deploy del monorepo)
# Copiá este archivo como `.env` en la raíz del proyecto.
# ================================================================

# Base de datos (usado por el contenedor `db` y el backend en Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-pass
POSTGRES_DB=centro

# IMPORTANTE: Postgres guarda la contraseña solo en el PRIMER arranque del volumen.
# Si cambiás POSTGRES_PASSWORD después, sincronizá con:
#   ./scripts/sync-postgres-password.sh
# o recreá el volumen (borra datos): docker compose down -v

# Autenticación (mínimo 32 caracteres)
JWT_SECRET=cambia-este-secreto-largo-en-produccion-min-32-chars

# Cookies HttpOnly del frontend (opcional).
# Por defecto se usa X-Forwarded-Proto (Cloudflare → secure en HTTPS).
# Poné false solo si entrás por http://IP:3005 sin tunnel.
# COOKIE_SECURE=true

# CORS: dominios desde los que el frontend pega al backend.
# Cloudflare Tunnel termina TLS y reenvía al contenedor por la
# red interna, así que es el dominio público del frontend.
CORS_ORIGINS=https://biblioteca.ies9018malargue.edu.ar

# Embeddings (Etapa 3)
# Backends: fake | openai | gemini
#   - fake:   vectores no semánticos (dev / sin API).
#   - gemini: gemini-embedding-001, FREE TIER de Google (reusa GEMINI_API_KEY).
#   - openai: text-embedding-3-* (requiere OPENAI_API_KEY con saldo).
# Recomendado para producción gratis: gemini.
EMBEDDING_BACKEND=gemini
# Para gemini: gemini-embedding-001 · Para openai: text-embedding-3-small
EMBEDDING_MODEL=gemini-embedding-001
# Solo si EMBEDDING_BACKEND=openai
OPENAI_API_KEY=

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# OCR (JPEG/PNG y fallback para PDFs escaneados)
OCR_LANGS=spa+eng
OCR_MAX_PAGES=50
OCR_MIN_NATIVE_CHARS=200
OCR_DPI=200

# Búsqueda tolerante a typos (pg_trgm)
FUZZY_THRESHOLD=0.2

# LLM (Etapa 4) — asistente IA
# Backends: fake | openai | groq | gemini
LLM_BACKEND=gemini
# Modelo Gemini (free tier): gemini-2.5-flash-latest, gemini-2.0-flash
LLM_MODEL=gemini-2.5-flash-latest
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
LLM_TOP_K=5
# Límite de consultas al asistente por usuario (protege el free tier)
CHAT_RATE_LIMIT=30/day
GROQ_API_KEY=
GEMINI_API_KEY=

# Moderación de contenido (requiere OPENAI_API_KEY)
MODERATION_ENABLED=true
MODERATION_MAX_PAGES=20

# Email (opcional; verificación y reset de contraseña)
PUBLIC_APP_URL=https://biblioteca.ies9018malargue.edu.ar
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Seguridad
REQUIRE_EMAIL_VERIFIED=false
ANTIVIRUS_ENABLED=false
UPLOAD_MAX_BYTES=52428800
